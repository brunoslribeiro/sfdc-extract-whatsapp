# Copie para .env e preencha valores
# Opcao A: Token pronto (se ja tiver)
# SF_INSTANCE_URL=https://seuorg.my.salesforce.com
# SF_ACCESS_TOKEN=SEU_TOKEN_OAUTH

# Opcao B: Client Credentials (recomendado neste projeto)
# URL do endpoint de token OAuth (use seu My Domain)
SF_AUTH_URL=https://seu-mydomain.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=SEU_CONNECTED_APP_CLIENT_ID
SF_CLIENT_SECRET=SEU_CONNECTED_APP_CLIENT_SECRET

# Opcional: se nao quiser derivar do SF_AUTH_URL, defina explicitamente
SF_INSTANCE_URL=https://seu-mydomain.my.salesforce.com

# Opcional: escopos/audience se exigidos pela sua org
# Para Conversation Data API, garanta o escopo sfap_api no token.
# SF_SCOPE=sfap_api
# SF_AUDIENCE=https://login.salesforce.com

# Opcional: versao da API
# SF_API_VERSION=62.0

# Opcional: base da Conversation Data API
# SF_CONVERSATION_API_BASE_URL=https://api.salesforce.com/platform/engagement/v1.0

# MongoDB (para auditoria/visualizacao)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sfdc_whatsapp
MONGO_MESSAGES_COLLECTION=whatsapp_messages
MONGO_CONVERSATIONS_COLLECTION=whatsapp_conversations
